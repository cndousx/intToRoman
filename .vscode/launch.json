{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MinGW Debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/mingw-x64-build-debug/intToRoman",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb", // 需要配置环境变量 gdb --version
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "MinGW Debug Cmake" // tasks.json中指定的任务
    },
