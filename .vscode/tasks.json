{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "MinGW Debug Cmake",
      "type": "shell",
      "command": "cmake --preset debug && cmake --build mingw-x64-vcpkg-build-debug",
      "group": "build"
    },
    {
      "label": "MinGW Release Cmake",
      "type": "shell",
      "command": "cmake --preset release && cmake --build mingw-x64-vcpkg-build-release",
      "group": "build"
    }
  ]
}
