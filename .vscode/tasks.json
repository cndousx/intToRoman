{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Debug Cmake",
      "type": "shell",
      "command": "cmake --preset debug && cmake --build vcpkg-build-debug",
      "group": "build"
    },
    {
      "label": "Release Cmake",
      "type": "shell",
      "command": "cmake --preset release && cmake --build vcpkg-build-release",
      "group": "build"
    }
  ]
}
