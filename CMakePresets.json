{
  "version": 3,
  "configurePresets": [
    {
      "name": "x64-vcpkg",
      "hidden": true,
      "generator": "Ninja",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "mingw-x64-debug",
      "inherits": "x64-vcpkg",
      "generator": "Ninja",
      "displayName": "Debug with vcpkg(x64-mingw)",
      "description": "vcpkg debug x64-mingw",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-static"
      },
      "binaryDir": "${sourceDir}/mingw-x64-build-debug"
    },
    {
      "name": "mingw-x64-release",
      "inherits": "x64-vcpkg",
      "generator": "Ninja",
      "displayName": "Release with vcpkg(x64-mingw)",
      "description": "vcpkg release x64-mingw",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-static-release"
      },
      "binaryDir": "${sourceDir}/mingw-x64-build-release"
    },
    {
      "name": "linux-x64-debug",
      "inherits": "x64-vcpkg",
      "generator": "Ninja",
      "displayName": "Debug with linux x64",
      "description": "debug build with linux x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      },
      "binaryDir": "${sourceDir}/linux-x64-build-debug"
    },
    {
      "name": "linux-x64-release",
      "inherits": "x64-vcpkg",
      "generator": "Ninja",
      "displayName": "Release with linux x64",
      "description": "release build with linux x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x64-linux-release"
      },
      "binaryDir": "${sourceDir}/linux-x64-build-release"
    }
  ]
}
